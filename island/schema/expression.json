{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./expression.json",
  "title": "Expression Schema",
  "description": "A body of work within an island, such as the User Manual.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "description",
    "modules"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "library": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "hero": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "rainbowLabel": {
              "type": "string"
            },
            "subtitle": {
              "type": "string"
            }
          }
        },
        "topNav": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "label"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "icon": {
                "type": "string"
              }
            }
          }
        },
        "quickLinks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "label"
            ],
            "properties": {
              "label": {
                "type": "string"
              },
              "emoji": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "modules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9-]+$"
      },
      "uniqueItems": true
    }
  }
}
