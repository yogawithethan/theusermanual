{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./page.json",
  "title": "Page Schema",
  "description": "A renderable page composed of portable blocks.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "kind",
    "summary",
    "blocks"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "landing",
        "overview",
        "lesson",
        "essay"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "blocks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "source"
            ],
            "properties": {
              "type": {
                "const": "richText"
              },
              "title": {
                "type": "string"
              },
              "source": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "markdown"
                ],
                "properties": {
                  "markdown": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "quote"
            ],
            "properties": {
              "type": {
                "const": "quote"
              },
              "quote": {
                "type": "string",
                "minLength": 1
              },
              "attribution": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type"
            ],
            "properties": {
              "type": {
                "const": "video"
              },
              "label": {
                "type": "string"
              },
              "placeholder": {
                "type": "string"
              },
              "description": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "type",
              "title",
              "body",
              "label",
              "href"
            ],
            "properties": {
              "type": {
                "const": "cta"
              },
              "kicker": {
                "type": "string"
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "body": {
                "type": "string",
                "minLength": 1
              },
              "label": {
                "type": "string",
                "minLength": 1
              },
              "href": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        ]
      }
    }
  }
}
