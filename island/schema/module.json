{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./module.json",
  "title": "Module Schema",
  "description": "A structured module inside an expression.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "title",
    "description",
    "pages"
  ],
  "properties": {
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "available",
        "in-progress",
        "locked"
      ]
    },
    "level": {
      "type": "string"
    },
    "entryPage": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "libraryLabel": {
          "type": "string"
        },
        "libraryMark": {
          "type": "string"
        },
        "detailIcon": {
          "type": "string"
        },
        "detailTitle": {
          "type": "string"
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "slug",
          "title",
          "kind",
          "summary"
        ],
        "properties": {
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "overview",
              "lesson",
              "essay",
              "landing"
            ]
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
